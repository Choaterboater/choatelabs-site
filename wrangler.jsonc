{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "choatelabs-site",
  "compatibility_date": "2026-05-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "LUMINA_DB",
      "database_name": "lumina-leaderboard",
      "database_id": "8fe6ce8f-73f5-4193-86ed-4d9cda29d24d"
    }
  ]
}
